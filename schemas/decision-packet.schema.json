{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecisionPacket",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "pr_url": { "type": "string", "format": "uri" },
    "head_sha": { "type": "string", "minLength": 1 },
    "recommendation": { "type": "string", "enum": ["approve", "hold"] },
    "open_risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "required": ["task_id", "pr_url", "head_sha", "recommendation", "open_risks"]
}
