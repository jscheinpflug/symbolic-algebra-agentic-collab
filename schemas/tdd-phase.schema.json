{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TDDPhaseArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feature_id",
    "phase",
    "feature_context",
    "depends_on_pr",
    "module_docs",
    "status",
    "updated_at"
  ],
  "properties": {
    "feature_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "phase": {
      "type": "string",
      "enum": [
        "TYPES",
        "TESTS",
        "IMPL"
      ]
    },
    "feature_context": {
      "type": "string",
      "pattern": "^artifacts/tdd/[a-z0-9][a-z0-9-]{2,63}/FEATURE\\.md$"
    },
    "depends_on_pr": {
      "type": [
        "string",
        "null"
      ]
    },
    "module_docs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^docs/modules/.+\\.md$"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready"
      ]
    },
    "updated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "phase": {
            "enum": [
              "TESTS",
              "IMPL"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "depends_on_pr": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
